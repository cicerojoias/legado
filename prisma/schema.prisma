generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERADOR
}

enum Loja {
  JOAO_PESSOA
  SANTA_RITA
  AMBAS
}

enum TipoLancamento {
  ENTRADA
  SAIDA
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  nome         String
  role         Role        @default(OPERADOR)
  lojaAutorizada Loja      @default(JOAO_PESSOA)
  lojaPadrao   Loja?       // Loja padrão ao fazer login (opcional, fallback = JOAO_PESSOA)
  pin_hash       String?     // PIN de 4 dígitos (hashed) p/ fast-auth
  pin_tentativas Int         @default(0)
  bloqueado_ate  DateTime?   // Timestamp para cooldown (lockout)
  ativo          Boolean     @default(true)
  notif_push     Boolean     @default(false)  // Recebe push notification diária
  notif_horario  String      @default("18:00") // Horário da notificação (HH:MM)
  
  lancamentos           Lancamento[]
  logs                  Log[]
  custos_fixos          CustoFixo[]
  push_subscriptions    WaPushSubscription[]
  conversation_reads    WaConversationRead[]
  assigned_tags         ConversationTag[]     @relation("assigned_tags")
  conversation_notes    WaConversationNote[]  @relation("conversation_note_author")

  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  @@index([email])
  @@index([lojaAutorizada])
  @@map("users")
}

model Lancamento {
  id           String         @id @default(uuid())
  tipo         TipoLancamento
  valor        Decimal        @db.Decimal(10, 2)
  descricao    String?
  metodo_pgto  String?        // Pix, Cartão, Dinheiro
  loja         Loja
  data_ref     DateTime       // A data que o lançamento se refere (Dashboard "Hoje")

  // Soft-delete: null = ativo, preenchido = excluído (ADR-0001)
  // NUNCA deletar fisicamente — integridade financeira e auditoria
  deletado_at  DateTime?

  usuario_id   String
  usuario      User           @relation(fields: [usuario_id], references: [id])

  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  // Índice composto inclui deletado_at: queries sempre filtram por NULL (registros ativos)
  // Planner usa o índice para loja + data_ref + deletado_at IS NULL sem full scan
  @@index([loja, data_ref, deletado_at])
  @@index([usuario_id])
  @@map("lancamentos")
}

model CustoFixo {
  id           String    @id @default(uuid())
  nome         String
  valor        Decimal   @db.Decimal(10, 2)
  loja         Loja
  dia_venc     Int       // Dia do mês que costuma vencer
  ativo        Boolean   @default(true) // false = desativado temporariamente sem excluir

  usuario_id   String
  usuario      User      @relation(fields: [usuario_id], references: [id])

  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([loja])
  @@index([ativo])
  @@map("custos_fixos")
}

model Log {
  id           String    @id @default(uuid())
  acao         String    // "LOGIN_SUCESSO", "LANCAMENTO_CRIADO", "LANCAMENTO_DELETADO"
  detalhe      String?   @db.Text
  
  usuario_id   String?
  usuario      User?     @relation(fields: [usuario_id], references: [id], onDelete: SetNull)

  created_at   DateTime  @default(now())

  @@index([acao, created_at])
  @@map("logs")
}

// ─── WhatsApp ────────────────────────────────────────────────────────────────

model WaContact {
  id         String           @id @default(uuid())
  phone      String           @unique // "5583911800251" (sem + e sem espaços)
  name       String?                  // nome que a Meta retorna
  wa_id      String           @unique // ID interno da Meta
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  conversations WaConversation[]

  @@map("wa_contacts")
}

model WaConversation {
  id              String     @id @default(uuid())
  contact_id      String     @unique
  contact         WaContact  @relation(fields: [contact_id], references: [id])
  status          String     @default("open") // open | resolved | waiting
  last_message_at DateTime?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  welcome_sent_at    DateTime?          // trava de dedup para mensagem de boas-vindas
  ia_ativa           Boolean    @default(false) // IA responde automaticamente nesta conversa

  messages           WaMessage[]
  notes              WaConversationNote[]
  conversation_reads WaConversationRead[]
  conversation_tags  ConversationTag[]

  @@index([last_message_at(sort: Desc)])
  @@index([status])
  @@map("wa_conversations")
}

model WaMessage {
  id              String         @id @default(uuid())
  conversation_id String
  conversation    WaConversation @relation(fields: [conversation_id], references: [id])
  wa_message_id   String?        @unique // ID da Meta (dedup)
  direction       String                 // inbound | outbound
  type            String         @default("text")
  content         String?        @db.Text
  mediaUrl        String?
  mediaId         String?                // Meta media ID — permite reprocessar se mediaUrl for null
  mimeType        String?
  status          String         @default("sent") // sent | delivered | read | failed
  sent_by         String?                // user id do operador (outbound)
  timestamp       DateTime
  created_at      DateTime       @default(now())

  // Reply
  replyToId       String?
  replyTo         WaMessage?     @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         WaMessage[]    @relation("MessageReply")
  replyToSnapshot String?        @db.VarChar(500) // snapshot do conteúdo citado no momento do envio

  // Reaction
  reaction        String?        // emoji da reação — null = sem reação

  // Forward
  forwarded       Boolean        @default(false)

  @@index([conversation_id, timestamp(sort: Desc)])
  @@map("wa_messages")
}

model WaConversationRead {
  id              String         @id @default(uuid())
  userId          String
  conversationId  String
  lastReadAt      DateTime       @default(now())
  unreadCount     Int            @default(0)

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation    WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([userId])
  @@index([conversationId])
  @@map("wa_conversation_reads")
}

model WaPushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique @db.VarChar(512)
  p256dh    String   @db.VarChar(100)
  auth      String   @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wa_push_subscriptions")
}

model WaSettings {
  id               String   @id @default("singleton")
  welcome_enabled  Boolean  @default(false)
  welcome_message  String?  @db.Text
  updated_at       DateTime @updatedAt

  @@map("wa_settings")
}

model WaTag {
  id         String   @id @default(uuid())
  name       String
  color      String   // "amber"|"rose"|"sky"|"violet"|"orange"|"teal"|"pink"|"indigo"|"lime"|"cyan"
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  conversation_tags ConversationTag[]

  @@unique([name])
  @@map("wa_tags")
}

model ConversationTag {
  id             String   @id @default(uuid())
  conversationId String
  tagId          String
  assignedBy     String?
  assignedAt     DateTime @default(now())

  conversation   WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag            WaTag          @relation(fields: [tagId], references: [id], onDelete: Restrict)
  assignedByUser User?          @relation("assigned_tags", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@unique([conversationId, tagId])
  @@index([conversationId])
  @@index([tagId])
  @@map("conversation_tags")
}

model WaMessageGeneration {
  id                String   @id @default(uuid())
  service_type      String   // banho_ouro | alianca | conserto | followup | outro
  input_context     String   @db.Text
  generated_message String   @db.Text
  was_used          Boolean  @default(false)
  client_name       String?
  created_by        String?  // user id do operador
  created_at        DateTime @default(now())

  @@map("wa_message_generations")
}

model WaConversationNote {
  id              String         @id @default(uuid())
  conversation_id String
  conversation    WaConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  author_id       String?
  author          User?          @relation("conversation_note_author", fields: [author_id], references: [id], onDelete: SetNull)
  content         String         @db.Text
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  deleted_at      DateTime?

  @@index([conversation_id, deleted_at, created_at])
  @@map("wa_conversation_notes")
}

