# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Serena MCP (estado local, não versionado)
.serena/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/src/generated/prisma

# docs & internal
CHANGELOG.md

# seeds & scripts
/prisma/seed*.ts
/scripts/

# local tools & caches
.cache/
.claude/

# screenshots & logs (root only)
/*.png
*.log
*.txt
/caixa_joaopessoa/

# default Next.js SVGs (keep manifest.json)
/public/*.svg

# serwist (generated service worker)
/public/sw.js
/public/sw.js.map
/public/serwist-worker-*.js
/public/serwist-worker-*.js.map

# temporary files
/tmp/
test.out

# Arquivos de contexto e testes locais
PROMPT_NEXT_CHAT.md
tests/

# Archive documentation
docs/archive/

.vercel
.env*.local
